		<DataType>
			<Name GUID="{E165FF93-CB57-49AA-B30B-28E416F7DE2A}" Namespace="TcIoXPlanar">XPlanarEvents</Name>
			<DisplayName TxtId=""><![CDATA[XPlanarEvents]]></DisplayName>
			<Comment TxtId=""><![CDATA[Manages all XPlanar event logger messages]]></Comment>
			<EventId>
				<Name Id="#x13170000">I0000_WritingDumpFile</Name>
				<DisplayName TxtId=""><![CDATA[Writing dump file: {0}]]></DisplayName>
				<Severity>Info</Severity>
			</EventId>
			<EventId>
				<Name Id="#x13170001">I0001_MoverRedetectionStarted</Name>
				<DisplayName TxtId=""><![CDATA[Mover redetection started]]></DisplayName>
				<Severity>Info</Severity>
			</EventId>
			<EventId>
				<Name Id="#x13170007">I0007_CoordinatedMoverComm_Started_IdentifyAndFindAllConfigured</Name>
				<DisplayName TxtId=""><![CDATA[Coordinated mover communication started to identify and rearrange all movers.]]></DisplayName>
				<Severity>Info</Severity>
			</EventId>
			<EventId>
				<Name Id="#x13170008">I0008_CoordinatedMoverComm_Successful</Name>
				<DisplayName TxtId=""><![CDATA[Coordinated mover communication finished.]]></DisplayName>
				<Severity>Info</Severity>
			</EventId>
			<EventId>
				<Name Id="#x13170009">I0009_CoordinatedMoverComm_MoverAssigned</Name>
				<DisplayName TxtId=""><![CDATA[BTN '{0}' was found at position {1}/{2} and assigned to mover object 0x{3,X}.]]></DisplayName>
				<Severity>Verbose</Severity>
			</EventId>
			<EventId>
				<Name Id="#x1317000A">I000A_CoordinatedMoverComm_MoverRemoved</Name>
				<DisplayName TxtId=""><![CDATA[Mover with object ID 0x{0,X} was removed from the system.]]></DisplayName>
				<Severity>Verbose</Severity>
			</EventId>
			<EventId>
				<Name Id="#x1317000B">I000B_CoordinatedMoverComm_Started_IdentifyAndAssignPossible</Name>
				<DisplayName TxtId=""><![CDATA[Coordinated mover communication started to identify and assign movers if possible.]]></DisplayName>
				<Severity>Info</Severity>
			</EventId>
			<EventId>
				<Name Id="#x1317000C">I000C_CoordinatedMoverComm_Started_ReadBTNs</Name>
				<DisplayName TxtId=""><![CDATA[Coordinated mover communication started to read BTN of all movers.]]></DisplayName>
				<Severity>Info</Severity>
			</EventId>
			<EventId>
				<Name Id="#x1317000D">I000D_CoordinatedMoverComm_Started_DetermineOrientations</Name>
				<DisplayName TxtId=""><![CDATA[Coordinated mover communication started to determine orientations of all movers.]]></DisplayName>
				<Severity>Info</Severity>
			</EventId>
			<EventId>
				<Name Id="#x1317000E">I000E_CoordinatedMoverComm_Started_DetermineOrientationsWithoutTurning</Name>
				<DisplayName TxtId=""><![CDATA[Coordinated mover communication started to determine orientations of all movers without assigning.]]></DisplayName>
				<Severity>Info</Severity>
			</EventId>
			<EventId>
				<Name Id="#x1317000F">I000F_CoordinatedMoverComm_PreparingMovers</Name>
				<DisplayName TxtId=""><![CDATA[Preparing movers for communication.]]></DisplayName>
				<Severity>Info</Severity>
			</EventId>
			<EventId>
				<Name Id="#x13170010">I0010_CoordinatedMoverComm_InProgress</Name>
				<DisplayName TxtId=""><![CDATA[Communication in progress...]]></DisplayName>
				<Severity>Info</Severity>
