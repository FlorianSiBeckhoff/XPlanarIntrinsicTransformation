					<PTCID>#x0317001b</PTCID>
					<ContextId>1</ContextId>
				</Parameter>
				<Parameter DisableCodeGeneration="true" CreateSymbol="true" Group="General">
					<Name>OperationMode</Name>
					<Comment><![CDATA[In simulation mode no hardware is needed.]]></Comment>
					<BitSize>16</BitSize>
					<BaseType GUID="{5DF5437A-337E-42DD-898A-21545D51180A}" Namespace="TcIoXPlanar">XPlanarOperationMode</BaseType>
					<Default>
						<EnumText>Normal</EnumText>
					</Default>
					<PTCID>#x03170010</PTCID>
					<ContextId>1</ContextId>
				</Parameter>
				<Parameter DisableCodeGeneration="true" Group="MoverDetection">
					<Name>StartMoverRedetection</Name>
					<Comment><![CDATA[Detects all movers on the system with mover type and X and Y position. The detection is based on sensor values of the tiles and therefore does not require a connected power voltage. Can only be set if all movers are disabled.]]></Comment>
					<BitSize>0</BitSize>
					<BaseType GUID="{FFFFFFFF-FFFF-FFFF-FFFF-FFFFFFFFFFFF}"/>
					<PTCID>#x03171002</PTCID>
					<ContextId>1</ContextId>
				</Parameter>
				<Parameter DisableCodeGeneration="true" Group="MoverDetection">
					<Name>DetectionMode</Name>
					<Comment><![CDATA[Select whether the configured type and count of mover is mandatory in detection.]]></Comment>
					<BitSize>16</BitSize>
					<BaseType GUID="{E6AFEF2D-3455-47DF-ABC9-E258AB316E9F}" Namespace="TcIoXPlanar">DetectionMode</BaseType>
					<Default>
						<EnumText>ConfiguredTypesAnyCounts</EnumText>
					</Default>
					<PTCID>#x03171006</PTCID>
					<ContextId>1</ContextId>
				</Parameter>
				<Parameter DisableCodeGeneration="true" Group="MoverCommunication">
					<Name>CoordinatedMoverCommunicationCommand</Name>
					<Comment><![CDATA[Offers the option of reading information from the mover and determining its orientation. It requires Id-Bumpers for all movers and a connected power voltage. Can only be set if all movers are disabled.]]></Comment>
					<BitSize>16</BitSize>
					<BaseType GUID="{2759DF82-72FC-48F3-AFA4-7EC2A03D6152}" Namespace="TcIoXPlanar">CoordinatedMoverCommCommand</BaseType>
					<Default>
						<EnumText>IdentifyAndFindAllConfigured</EnumText>
					</Default>
					<PTCID>#x03171007</PTCID>
					<ContextId>1</ContextId>
				</Parameter>
				<Parameter DisableCodeGeneration="true" Group="MoverCommunication">
					<Name>MoverAlignmentForCommunication</Name>
					<Comment><![CDATA[For best results of mover communication the movers must be aligned to 0° in c axis. If set to Auto, this will be done automatically when a mover communication command is sent.]]></Comment>
					<BitSize>16</BitSize>
					<BaseType GUID="{F15354CB-6597-4553-B041-25DC4000DFC3}" Namespace="TcIoXPlanar">MoverAlignmentForCommunication</BaseType>
					<Default>
						<EnumText>Auto</EnumText>
					</Default>
					<PTCID>#x03171003</PTCID>
					<ContextId>1</ContextId>
				</Parameter>
				<Parameter HideParameter="true" DisableCodeGeneration="true" Group="MoverCommunication">
					<Name>UseHigherLimitsForPositionChangeCheck</Name>
					<Comment><![CDATA[For slippery surfaces, it may be useful to allow more position change. Note: In rare cases, this may result in incorrectly determined orientations.]]></Comment>
					<BitSize>8</BitSize>
					<BaseType GUID="{18071995-0000-0000-0000-000000000030}">BOOL</BaseType>
					<Default>
						<EnumText>FALSE</EnumText>
