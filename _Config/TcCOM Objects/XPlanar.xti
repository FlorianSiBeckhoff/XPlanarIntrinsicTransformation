				</Parameter>
				<Parameter DisableCodeGeneration="true" Group="ProcessingUnit">
					<Name>EtherCatMasterSyncTaskObjectID</Name>
					<Comment><![CDATA[This is the task whose EtherCAT master is the EtherCAT DC (distributed clocks) master.]]></Comment>
					<BitSize>32</BitSize>
					<BaseType GUID="{18071995-0000-0000-0000-00000000000F}">OTCID</BaseType>
					<PTCID>#x03170000</PTCID>
					<ContextId>1</ContextId>
				</Parameter>
				<Parameter HideParameter="true" DisableCodeGeneration="true" Group="General">
					<Name>WriteMlLog</Name>
					<Comment><![CDATA[TRUE: Write a log file for start up of ML-Modules.]]></Comment>
					<BitSize>8</BitSize>
					<BaseType GUID="{18071995-0000-0000-0000-000000000030}">BOOL</BaseType>
					<Default>
						<EnumText>TRUE</EnumText>
					</Default>
