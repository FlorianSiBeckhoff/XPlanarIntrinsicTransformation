				<Severity>Warning</Severity>
			</EventId>
			<EventId>
				<Name Id="#x23176005">W6005_TileSwitchPositionImplausibleWarning</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] FB Inputs implausible switch position (expected: {1}, actual: {2}).]]></DisplayName>
				<Severity>Warning</Severity>
			</EventId>
			<EventId>
