				<Severity>Warning</Severity>
			</EventId>
			<EventId>
				<Name Id="#x23175004">W5004_PowerLimitReached</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] At least one of the used tiles reached power limit.]]></DisplayName>
