				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] Activate mover transfer failed.]]></DisplayName>
				<Severity>Error</Severity>
			</EventId>
			<EventId>
				<Name Id="#x33175041">E5041_Communication_MoverTransferNotActivated</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] Mover is between to XPlanar systems and mover transfer is not activated. Communication aborted.]]></DisplayName>
				<Severity>Error</Severity>
			</EventId>
			<EventId>
				<Name Id="#x33175042">E5042_Communication_OrientationBumperOutsideTile</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] Mover bumper exceeds the tile area. Mover orientation cannot be determined.]]></DisplayName>
				<Severity>Error</Severity>
			</EventId>
			<EventId>
				<Name Id="#x33175043">E5043_Communication_OrientationWrongMoverFirmware</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] Wrong mover firmware. Firmware version must be greater than 3. Mover orientation cannot be determined.]]></DisplayName>
				<Severity>Error</Severity>
			</EventId>
			<EventId>
				<Name Id="#x33175044">E5044_Communication_TransmissionFailed</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] Transmission of the message to the mover failed. Mover communication failed.]]></DisplayName>
				<Severity>Error</Severity>
			</EventId>
			<EventId>
				<Name Id="#x33175045">E5045_Communication_ReceptionFailed</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] The signal level of the mover answer is too low. Mover communication failed.]]></DisplayName>
				<Severity>Error</Severity>
			</EventId>
			<EventId>
				<Name Id="#x33175046">E5046_Communication_DecodingFailed</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] The message received from the mover is invalid. Mover communication failed.]]></DisplayName>
				<Severity>Error</Severity>
			</EventId>
			<EventId>
				<Name Id="#x33175047">E5047_Communication_OrientingMoverFailed</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] Mover is rotated and cannot be orientated. Communication aborted.]]></DisplayName>
				<Severity>Error</Severity>
			</EventId>
			<EventId>
				<Name Id="#x33175048">E5048_Communication_MoverPositionChanged</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] Mover position changed during communication. Mover orientation cannot be determined.]]></DisplayName>
				<Severity>Error</Severity>
			</EventId>
			<EventId>
				<Name Id="#x33175049">E5049_Communication_CouldNotEstablishCommunication</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] No communication could be established with the mover. Mover communication failed.]]></DisplayName>
				<Severity>Error</Severity>
			</EventId>
			<EventId>
				<Name Id="#x33176002">E6002_EtherCatCommunicationLost</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] EtherCAT communication is lost. System is shut down.]]></DisplayName>
				<Severity>Error</Severity>
			</EventId>
			<EventId>
				<Name Id="#x33176004">E6004_PowerSupplyTemperatureTooHigh</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] Power supply temperature ({1,f} °C) exceeds the limit of {2,f} °C. System is shut down.]]></DisplayName>
				<Severity>Error</Severity>
			</EventId>
			<EventId>
				<Name Id="#x33176005">E6005_TileTemperatureTooHigh</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] Tile temperature {1} ({2,f} °C) exceeds the limit of {3,f} °C. System is shut down.]]></DisplayName>
				<Severity>Error</Severity>
			</EventId>
			<EventId>
				<Name Id="#x33176007">E6007_HardwareError</Name>
