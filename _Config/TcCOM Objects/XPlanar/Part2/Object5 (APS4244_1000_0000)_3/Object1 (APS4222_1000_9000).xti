			</EventId>
			<EventId>
				<Name Id="#x2317500C">W500C_InvalidControllerParameters</Name>
				<DisplayName TxtId=""><![CDATA[[Event ID: 0x{0,X}] Invalid controller parameters of axis {1}. Controller parameters are set to default.]]></DisplayName>
