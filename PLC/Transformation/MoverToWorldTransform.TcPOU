<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="MoverToWorldTransform" Id="{4971da7f-4d4e-4594-a113-076959603112}" SpecialFunc="None">
    <Declaration><![CDATA[(* ============================================================================
   FUNCTION BLOCK: FB_MoverToWorldTransform
   ----------------------------------------------------------------------------
   PURPOSE:
     Forward transforms a mover tooling position from the mover (local) frame
     into the world coordinate system of the tile.

     Coordinate chain:
       World (Tile) <-- Mover Pose <-- Tool Offset <-- Tool Tip

     Rotation convention: INTRINSIC XYZ (Tait-Bryan)
       Rx applied first (roll around X), then Ry (pitch around Y'),
       then Rz (yaw around Z'').
       Combined matrix: R = Rz * Ry * Rx

     Runs every scan cycle — no enable trigger required.
     All output angles are ABSOLUTE (unbounded, no rollover).

   INPUTS:
     MoverX, MoverY, MoverZ          : Mover position in tile world [mm]
     MoverRx, MoverRy, MoverRz       : Mover orientation in tile world [°]
                                       XYZ intrinsic: Rx first, Rz last
     ToolOffsetX/Y/Z                 : Tool offset in mover-local frame [mm]
     ToolOffsetRx/Ry/Rz             : Tool orientation offset in mover frame [°]
     Reset                           : Clears accumulated angle unwrap history

   OUTPUTS:
     WorldX, WorldY, WorldZ          : Tool tip position in tile world [mm]
     WorldRx, WorldRy, WorldRz       : Tool tip orientation in tile world [°]
                                       ABSOLUTE — never rolls over ±360°
     Error                           : Set TRUE when asin clamp fires (near ±90° pitch)
   ============================================================================ *)

FUNCTION_BLOCK MoverToWorldTransform
VAR_INPUT
    MoverX          : LREAL;
    MoverY          : LREAL;
    MoverZ          : LREAL;
    MoverRx         : LREAL;   (* Roll  around X [°] — applied first  *)
    MoverRy         : LREAL;   (* Pitch around Y [°] — applied second *)
    MoverRz         : LREAL;   (* Yaw   around Z [°] — applied last   *)

    ToolOffsetX     : LREAL;
    ToolOffsetY     : LREAL;
    ToolOffsetZ     : LREAL;
    ToolOffsetRx    : LREAL;
    ToolOffsetRy    : LREAL;
    ToolOffsetRz    : LREAL;

    Reset           : BOOL;
END_VAR

VAR_OUTPUT
    WorldX          : LREAL;
    WorldY          : LREAL;
    WorldZ          : LREAL;
    WorldRx         : LREAL;   (* Absolute, no rollover *)
    WorldRy         : LREAL;   (* Absolute, no rollover *)
    WorldRz         : LREAL;   (* Absolute, no rollover *)
    Error           : BOOL;
END_VAR

VAR
    ResetPrev       : BOOL;

    R_M             : ARRAY[1..3, 1..3] OF LREAL;   (* Mover rotation matrix    *)
    R_T             : ARRAY[1..3, 1..3] OF LREAL;   (* Tool offset rot. matrix  *)
    R_W             : ARRAY[1..3, 1..3] OF LREAL;   (* Combined world rot. matrix *)

    Dx              : LREAL;   (* Tool offset rotated into world frame *)
    Dy              : LREAL;
    Dz              : LREAL;

    RawRx           : LREAL;   (* Wrapped angles extracted from R_W *)
    RawRy           : LREAL;
    RawRz           : LREAL;

    PrevRawRx       : LREAL;
    PrevRawRy       : LREAL;
    PrevRawRz       : LREAL;

    UnwrapOffRx     : LREAL;   (* Accumulated unwrap corrections *)
    UnwrapOffRy     : LREAL;
    UnwrapOffRz     : LREAL;

    FirstCalc       : BOOL := TRUE;

    Cx              : LREAL;   (* Trig intermediates — mover *)
    Sx              : LREAL;
    Cy              : LREAL;
    Sy              : LREAL;
    Cz              : LREAL;
    Sz              : LREAL;

    Cx2             : LREAL;   (* Trig intermediates — tool offset *)
    Sx2             : LREAL;
    Cy2             : LREAL;
    Sy2             : LREAL;
    Cz2             : LREAL;
    Sz2             : LREAL;

    SyWorld         : LREAL;   (* Clamped sin(Ry_world) for gimbal guard *)
END_VAR

VAR CONSTANT
    DEG2RAD         : LREAL := 0.017453292519943295;
    RAD2DEG         : LREAL := 57.29577951308232;
    HALF_TURN       : LREAL := 180.0;
    FULL_TURN       : LREAL := 360.0;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* ── Reset unwrap history on rising edge ────────────────────────────────────── *)
IF Reset AND NOT ResetPrev THEN
    UnwrapOffRx := 0.0;
    UnwrapOffRy := 0.0;
    UnwrapOffRz := 0.0;
    PrevRawRx   := 0.0;
    PrevRawRy   := 0.0;
    PrevRawRz   := 0.0;
    FirstCalc   := TRUE;
    Error       := FALSE;
END_IF
ResetPrev := Reset;

Error := FALSE;

(* ============================================================================
   MOVER ROTATION MATRIX  R_M = Rz(MoverRz) * Ry(MoverRy) * Rx(MoverRx)
   ============================================================================ *)
Cx := COS(MoverRx * DEG2RAD);
Sx := SIN(MoverRx * DEG2RAD);
Cy := COS(MoverRy * DEG2RAD);
Sy := SIN(MoverRy * DEG2RAD);
Cz := COS(MoverRz * DEG2RAD);
Sz := SIN(MoverRz * DEG2RAD);

R_M[1,1] :=  Cy * Cz;
R_M[1,2] :=  Sx * Sy * Cz - Cx * Sz;
R_M[1,3] :=  Cx * Sy * Cz + Sx * Sz;

R_M[2,1] :=  Cy * Sz;
R_M[2,2] :=  Sx * Sy * Sz + Cx * Cz;
R_M[2,3] :=  Cx * Sy * Sz - Sx * Cz;

R_M[3,1] := -Sy;
R_M[3,2] :=  Sx * Cy;
R_M[3,3] :=  Cx * Cy;

(* ============================================================================
   TOOL OFFSET ROTATION MATRIX  R_T = Rz(ToolOffsetRz) * Ry(ToolOffsetRy) * Rx(ToolOffsetRx)
   ============================================================================ *)
Cx2 := COS(ToolOffsetRx * DEG2RAD);
Sx2 := SIN(ToolOffsetRx * DEG2RAD);
Cy2 := COS(ToolOffsetRy * DEG2RAD);
Sy2 := SIN(ToolOffsetRy * DEG2RAD);
Cz2 := COS(ToolOffsetRz * DEG2RAD);
Sz2 := SIN(ToolOffsetRz * DEG2RAD);

R_T[1,1] :=  Cy2 * Cz2;
R_T[1,2] :=  Sx2 * Sy2 * Cz2 - Cx2 * Sz2;
R_T[1,3] :=  Cx2 * Sy2 * Cz2 + Sx2 * Sz2;

R_T[2,1] :=  Cy2 * Sz2;
R_T[2,2] :=  Sx2 * Sy2 * Sz2 + Cx2 * Cz2;
R_T[2,3] :=  Cx2 * Sy2 * Sz2 - Sx2 * Cz2;

R_T[3,1] := -Sy2;
R_T[3,2] :=  Sx2 * Cy2;
R_T[3,3] :=  Cx2 * Cy2;

(* ============================================================================
   COMBINED WORLD ROTATION  R_W = R_M * R_T
   ============================================================================ *)
R_W[1,1] := R_M[1,1]*R_T[1,1] + R_M[1,2]*R_T[2,1] + R_M[1,3]*R_T[3,1];
R_W[1,2] := R_M[1,1]*R_T[1,2] + R_M[1,2]*R_T[2,2] + R_M[1,3]*R_T[3,2];
R_W[1,3] := R_M[1,1]*R_T[1,3] + R_M[1,2]*R_T[2,3] + R_M[1,3]*R_T[3,3];

R_W[2,1] := R_M[2,1]*R_T[1,1] + R_M[2,2]*R_T[2,1] + R_M[2,3]*R_T[3,1];
R_W[2,2] := R_M[2,1]*R_T[1,2] + R_M[2,2]*R_T[2,2] + R_M[2,3]*R_T[3,2];
R_W[2,3] := R_M[2,1]*R_T[1,3] + R_M[2,2]*R_T[2,3] + R_M[2,3]*R_T[3,3];

R_W[3,1] := R_M[3,1]*R_T[1,1] + R_M[3,2]*R_T[2,1] + R_M[3,3]*R_T[3,1];
R_W[3,2] := R_M[3,1]*R_T[1,2] + R_M[3,2]*R_T[2,2] + R_M[3,3]*R_T[3,2];
R_W[3,3] := R_M[3,1]*R_T[1,3] + R_M[3,2]*R_T[2,3] + R_M[3,3]*R_T[3,3];

(* ============================================================================
   WORLD POSITION
   Tool offset translated by R_M into the world frame, added to mover position
   ============================================================================ *)
Dx := R_M[1,1]*ToolOffsetX + R_M[1,2]*ToolOffsetY + R_M[1,3]*ToolOffsetZ;
Dy := R_M[2,1]*ToolOffsetX + R_M[2,2]*ToolOffsetY + R_M[2,3]*ToolOffsetZ;
Dz := R_M[3,1]*ToolOffsetX + R_M[3,2]*ToolOffsetY + R_M[3,3]*ToolOffsetZ;

WorldX := MoverX + Dx;
WorldY := MoverY + Dy;
WorldZ := MoverZ + Dz;

(* ============================================================================
   EXTRACT XYZ EULER ANGLES FROM R_W
     Ry = asin( -R_W[3,1] )
     Rx = atan2(  R_W[3,2],  R_W[3,3] )
     Rz = atan2(  R_W[2,1],  R_W[1,1] )
   R_W[3,1] clamped to [-1, 1] to prevent NaN at the ±90° pitch singularity
   ============================================================================ *)
SyWorld := R_W[3,1];
IF SyWorld >  1.0 THEN SyWorld :=  1.0; Error := TRUE; END_IF
IF SyWorld < -1.0 THEN SyWorld := -1.0; Error := TRUE; END_IF

RawRy := ASIN(-SyWorld)            * RAD2DEG;
RawRx := ATAN2(R_W[3,2], R_W[3,3]) * RAD2DEG;
RawRz := ATAN2(R_W[2,1], R_W[1,1]) * RAD2DEG;

(* ============================================================================
   ANGLE UNWRAP — prevent ±360° rollover
   ASIN output is bounded to [-90, +90] and ATAN2 to [-180, +180], so a raw
   angle can jump at most 360° per cycle. A single IF per axis is sufficient.
   ============================================================================ *)
IF FirstCalc THEN
    PrevRawRx   := RawRx;
    PrevRawRy   := RawRy;
    PrevRawRz   := RawRz;
    UnwrapOffRx := 0.0;
    UnwrapOffRy := 0.0;
    UnwrapOffRz := 0.0;
    FirstCalc   := FALSE;
ELSE
    IF (RawRx - PrevRawRx) >  HALF_TURN THEN UnwrapOffRx := UnwrapOffRx - FULL_TURN; END_IF
    IF (RawRx - PrevRawRx) < -HALF_TURN THEN UnwrapOffRx := UnwrapOffRx + FULL_TURN; END_IF

    IF (RawRy - PrevRawRy) >  HALF_TURN THEN UnwrapOffRy := UnwrapOffRy - FULL_TURN; END_IF
    IF (RawRy - PrevRawRy) < -HALF_TURN THEN UnwrapOffRy := UnwrapOffRy + FULL_TURN; END_IF

    IF (RawRz - PrevRawRz) >  HALF_TURN THEN UnwrapOffRz := UnwrapOffRz - FULL_TURN; END_IF
    IF (RawRz - PrevRawRz) < -HALF_TURN THEN UnwrapOffRz := UnwrapOffRz + FULL_TURN; END_IF

    PrevRawRx := RawRx;
    PrevRawRy := RawRy;
    PrevRawRz := RawRz;
END_IF

(* ── Absolute output angles ─────────────────────────────────────────────────── *)
WorldRx := RawRx + UnwrapOffRx;
WorldRy := RawRy + UnwrapOffRy;
WorldRz := RawRz + UnwrapOffRz;
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>