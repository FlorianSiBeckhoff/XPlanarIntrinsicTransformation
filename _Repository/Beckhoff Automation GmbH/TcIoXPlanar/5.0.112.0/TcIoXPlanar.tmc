        <Group Collapsed="true">MovementAreas</Group>
        <Group Collapsed="true">ParametrizationSets</Group>
        <Group Collapsed="true">ProcessingUnit</Group>
        <Group Collapsed="true">ProcessingLines</Group>
        <Group Collapsed="true">Peers</Group>
        <Group Collapsed="true">Multicomputing</Group>
        <Group Collapsed="true">Calibration</Group>
        <Group Collapsed="true">CycleTimeBalancing</Group>
        <!-- TraceLevelMax -->
        <Parameter HideParameter="true" Group="General">
          <Name>TraceLevelMax</Name>
          <Comment>Controls the amount of log messages.</Comment>
          <BaseType GUID="{8007ae3b-86bb-40f2-b385-ef87fcc239a4}">TcTraceLevel</BaseType>
          <Default>
            <EnumText>tlInfo</EnumText>
          </Default>
          <PTCID>#x03002103</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
        <!-- EtherCatMasterSyncTaskObjectID -->
        <Parameter DisableCodeGeneration="true" Group="ProcessingUnit">
          <Name>EtherCatMasterSyncTaskObjectID</Name>
          <Comment>This is the task whose EtherCAT master is the EtherCAT DC (distributed clocks) master.</Comment>
          <BaseType GUID="{18071995-0000-0000-0000-00000000000F}">OTCID</BaseType>
          <PTCID>#x03170000</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
        <!-- WriteMlLog -->
        <Parameter DisableCodeGeneration="true" HideParameter="true" Group="General">
          <Name>WriteMlLog</Name>
          <Comment>TRUE: Write a log file for start up of ML-Modules.</Comment>
          <BaseType GUID="{18071995-0000-0000-0000-000000000030}">BOOL</BaseType>
          <Default>
            <EnumText>TRUE</EnumText>
          </Default>
          <PTCID>#x03170001</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
        <!-- MlInstructionSet -->
        <Parameter DisableCodeGeneration="true" HideParameter="true" Group="General">
          <Name>MlInstructionSet</Name>
          <Comment>Instruction Set for ML computation</Comment>
          <BaseType GUID="{3EC57F0F-F0D7-4461-8C27-CB470DE69EE2}" Namespace="TcIoXPlanar">MlInstructionSet</BaseType>
          <PTCID>#x0317001B</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
        <!-- OperationMode -->
        <Parameter DisableCodeGeneration="true" Group="General">
          <Name>OperationMode</Name>
          <Comment>In simulation mode no hardware is needed.</Comment>
          <BaseType GUID="{5DF5437A-337E-42DD-898A-21545D51180A}" Namespace="TcIoXPlanar">XPlanarOperationMode</BaseType>
          <Default>
            <EnumText>Normal</EnumText>
          </Default>
          <PTCID>#x03170010</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
        <!-- StartMoverRedetection -->
        <Parameter DisableCodeGeneration="true" Group="MoverDetection">
          <Name>StartMoverRedetection</Name>
          <Comment>Detects all movers on the system with mover type and X and Y position. The detection is based on sensor values of the tiles and therefore does not require a connected power voltage. Can only be set if all movers are disabled.</Comment>
          <PTCID>#x03171002</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
        <!-- DetectionMode -->
        <Parameter DisableCodeGeneration="true" Group="MoverDetection">
          <Name>DetectionMode</Name>
          <Comment>Select whether the configured type and count of mover is mandatory in detection.</Comment>
          <BaseType GUID="{E6AFEF2D-3455-47DF-ABC9-E258AB316E9F}" Namespace="TcIoXPlanar">DetectionMode</BaseType>
          <Default>
            <EnumText>ConfiguredTypesAnyCounts</EnumText>
          </Default>
          <PTCID>#x03171006</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
        <!-- CoordinatedMoverCommunicationCommand -->
        <Parameter DisableCodeGeneration="true" Group="MoverCommunication">
          <Name>CoordinatedMoverCommunicationCommand</Name>
          <Comment>Offers the option of reading information from the mover and determining its orientation. It requires Id-Bumpers for all movers and a connected power voltage. Can only be set if all movers are disabled.</Comment>
          <BaseType GUID="{2759DF82-72FC-48F3-AFA4-7EC2A03D6152}" Namespace="TcIoXPlanar">CoordinatedMoverCommCommand</BaseType>
          <Default>
            <EnumText>IdentifyAndFindAllConfigured</EnumText>
          </Default>
          <PTCID>#x03171007</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
        <!-- MoverAlignmentForCommunication -->
        <Parameter DisableCodeGeneration="true" Group="MoverCommunication">
          <Name>MoverAlignmentForCommunication</Name>
          <Comment>For best results of mover communication the movers must be aligned to 0° in c axis. If set to Auto, this will be done automatically when a mover communication command is sent.</Comment>
          <BaseType GUID="{F15354CB-6597-4553-B041-25DC4000DFC3}" Namespace="TcIoXPlanar">MoverAlignmentForCommunication</BaseType>
          <Default>
            <EnumText>Auto</EnumText>
          </Default>
          <PTCID>#x03171003</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
        <!-- UseHigherLimitsForPositionChangeCheck -->
        <Parameter DisableCodeGeneration="true" HideParameter="true" Group="MoverCommunication">
          <Name>UseHigherLimitsForPositionChangeCheck</Name>
          <Comment>For slippery surfaces, it may be useful to allow more position change. Note: In rare cases, this may result in incorrectly determined orientations.</Comment>
          <BaseType GUID="{18071995-0000-0000-0000-000000000030}">BOOL</BaseType>
          <Default>
            <EnumText>FALSE</EnumText>
          </Default>
          <PTCID>#x03171012</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
