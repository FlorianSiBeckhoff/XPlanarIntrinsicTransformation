          <Name>internalEstimatedPosition</Name>
          <Type GUID="{5AC0538E-BDFA-4B58-A6B5-99E997DABADA}" ReferenceTo="true">MoverVector</Type>
          <BitSize X64="64">32</BitSize>
        </Parameter>
        <Parameter>
          <Name>externalEstimatedPosition</Name>
          <Type GUID="{5AC0538E-BDFA-4B58-A6B5-99E997DABADA}" ReferenceTo="true">MoverVector</Type>
          <BitSize X64="64">32</BitSize>
        </Parameter>
        <Parameter>
          <Name>externalMeasuredPosition</Name>
          <Type GUID="{5AC0538E-BDFA-4B58-A6B5-99E997DABADA}" ReferenceTo="true">MoverVector</Type>
          <BitSize X64="64">32</BitSize>
        </Parameter>
      </Method>
      <Relations>
        <Relation>
          <Type GUID="{2137AC36-123E-4F5C-B41C-2BB63239FB6C}">IXPlanarExternalFeedback</Type>
        </Relation>
      </Relations>
    </DataType>
    <!-- XPlanarEvents (After changes, an update of XPlanarTcEventEntries.h is necessary!) -->
    <DataType>
      <Name GUID="{E165FF93-CB57-49AA-B30B-28E416F7DE2A}" Namespace="TcIoXPlanar">XPlanarEvents</Name>
      <DisplayName TxtId="">XPlanarEvents</DisplayName>
      <Comment TxtId="">Manages all XPlanar event logger messages</Comment>
      <!-- Infos -->
      <EventId>
        <Name Id="#x13170000">I0000_WritingDumpFile</Name>
        <DisplayName TxtId="">Writing dump file: {0}</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x13170001">I0001_MoverRedetectionStarted</Name>
        <DisplayName TxtId="">Mover redetection started</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x13170007">I0007_CoordinatedMoverComm_Started_IdentifyAndFindAllConfigured</Name>
        <DisplayName TxtId="">Coordinated mover communication started to identify and rearrange all movers.</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x13170008">I0008_CoordinatedMoverComm_Successful</Name>
        <DisplayName TxtId="">Coordinated mover communication finished.</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x13170009">I0009_CoordinatedMoverComm_MoverAssigned</Name>
        <DisplayName TxtId="">BTN '{0}' was found at position {1}/{2} and assigned to mover object 0x{3,X}.</DisplayName>
        <Severity>Verbose</Severity>
      </EventId>
      <EventId>
        <Name Id="#x1317000A">I000A_CoordinatedMoverComm_MoverRemoved</Name>
        <DisplayName TxtId="">Mover with object ID 0x{0,X} was removed from the system.</DisplayName>
        <Severity>Verbose</Severity>
      </EventId>
      <EventId>
        <Name Id="#x1317000B">I000B_CoordinatedMoverComm_Started_IdentifyAndAssignPossible</Name>
        <DisplayName TxtId="">Coordinated mover communication started to identify and assign movers if possible.</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x1317000C">I000C_CoordinatedMoverComm_Started_ReadBTNs</Name>
        <DisplayName TxtId="">Coordinated mover communication started to read BTN of all movers.</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x1317000D">I000D_CoordinatedMoverComm_Started_DetermineOrientations</Name>
        <DisplayName TxtId="">Coordinated mover communication started to determine orientations of all movers.</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x1317000E">I000E_CoordinatedMoverComm_Started_DetermineOrientationsWithoutTurning</Name>
        <DisplayName TxtId="">Coordinated mover communication started to determine orientations of all movers without assigning.</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x1317000F">I000F_CoordinatedMoverComm_PreparingMovers</Name>
        <DisplayName TxtId="">Preparing movers for communication.</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x13170010">I0010_CoordinatedMoverComm_InProgress</Name>
        <DisplayName TxtId="">Communication in progress...</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x13170011">I0011_CoordinatedMoverComm_RearrangingMovers</Name>
        <DisplayName TxtId="">Rearrange movers.</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x13175000">I5000_DeterminedNcCycleTime</Name>
        <DisplayName TxtId="">Determined NC cycle time: {0} s</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x13175001">I5001_Communication_Started</Name>
        <DisplayName TxtId="">Mover communication started.</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x13175002">I5002_Communication_FinishedSuccessfully</Name>
        <DisplayName TxtId="">Mover communication finished successfully.</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x13175003">I5003_Communication_OrientationDeterminationStarted</Name>
        <DisplayName TxtId="">Mover orientation determination started.</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x13175004">I5004_Communication_OrientationDeterminationSuccessful</Name>
        <DisplayName TxtId="">Mover orientation determination finished successfully.</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x13175005">I5005_Communication_FileTransferStarted</Name>
        <DisplayName TxtId="">Mover file transfer started.</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <EventId>
        <Name Id="#x13175006">I5006_Communication_FileTransferSuccessful</Name>
        <DisplayName TxtId="">Mover file transfer finished successfully.</DisplayName>
        <Severity>Info</Severity>
      </EventId>
      <!-- Warnings -->
      <EventId>
        <Name Id="#x23175000">W5000_ParametrizationSetNotFound</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Defined parametrization set could not be found. Hence, parameters haven't been changed.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23175001">W5001_ImplausibleMoverPosition</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Implausible mover position. Mover was removed from current movement area.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23175002">W5002_InvalidMoverBasicInertia</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Invalid basic inertia. Basic inertia is set to standard inertia (plain mover).</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23175003">W5003_InvalidPayloadInertia</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Invalid payload inertia. Payload inertia is set to zero.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23175004">W5004_PowerLimitReached</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] At least one of the used tiles reached power limit.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23175006">W5006_CurrentLimitReached</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] At least one of the used tiles reached current limit.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23175009">W5009_InvalidFeedback</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Invalid mover feedback. Mover was removed from current movement area.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x2317500C">W500C_InvalidControllerParameters</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Invalid controller parameters of axis {1}. Controller parameters are set to default.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x2317500D">W500D_InvalidFeedforwardParameters</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Invalid feedforward parameters of axis {1}. Feedforward parameters are set to default.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x2317500E">W500E_InvalidObserverParameters</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Invalid observer parameters of axis {1}. Observer parameters are set to default.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23175012">W5012_ExternalFeedbackInterfaceMissing</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Failed to retrieve external feedback interface. Check the external feedback OID parameter is correct.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23175013">W5013_InvalidExternalFeedbackObserverParameters</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Invalid external feedback observer parameters of axis {1}. Observer parameters are set to default.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23175014">W5014_InvalidIdentifiedMass</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] There is either no payload on the mover to be detected or the payload is too light (less than 0.1 kg).</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23175015">W5015_ForceOrPowerLimitReached</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] During payload identification process the force or power limits by the tile were exceeded and the result would be meaningless.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23175016">W5016_PositionOffsetOutOfAllowedRange</Name>
