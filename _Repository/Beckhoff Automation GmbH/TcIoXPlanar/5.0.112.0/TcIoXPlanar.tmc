        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33178006">E8006_TileHardwareError</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] One tile of this part has an error. The part, its tiles and its movers are shutting down.</DisplayName>
