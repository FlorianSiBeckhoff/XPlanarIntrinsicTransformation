      <EnumInfo>
        <Text>Off</Text>
        <Enum>0</Enum>
      </EnumInfo>
      <EnumInfo>
        <Text>UseAsControlPosition</Text>
        <Enum>1</Enum>
      </EnumInfo>
      <Default>
        <EnumText>Off</EnumText>
      </Default>
      <Properties>
        <Property>
          <Name>plcAttribute_qualified_only</Name>
        </Property>
      </Properties>
      <Relations>
        <Relation>
          <Type GUID="{6B3A55AD-E833-4E2A-82D8-4D0088DD8F68}" Namespace="TcIoXPlanar">ExternalFeedbackMode</Type>
