    <!-- DiagHistoryMessages -->
    <DataType>
      <Name GUID="{95C60707-A3D1-4BF8-88A8-86AB5876EFBB}" Namespace="TcIoXPlanar">DiagHistoryMessages</Name>
      <Comment TxtId="" />
      <SubItem>
        <Name>Timestamp</Name>
        <Type GUID="{18071995-0000-0000-0000-000000000047}">DCTIME</Type>
      </SubItem>
      <SubItem>
        <Name>Type</Name>
        <Type GUID="{18071995-0000-0000-0000-000000000002}">USINT</Type>
        <EnumInfo>
          <Text><![CDATA[CoeInfo]]></Text>
          <Enum>0</Enum>
        </EnumInfo>
        <EnumInfo>
          <Text><![CDATA[CoeWarning]]></Text>
          <Enum>1</Enum>
        </EnumInfo>
        <EnumInfo>
          <Text><![CDATA[CoeError]]></Text>
          <Enum>2</Enum>
        </EnumInfo>
      </SubItem>
      <SubItem>
        <Name>MessageId</Name>
        <Type GUID="{18071995-0000-0000-0000-000100000007}">STRING(7)</Type>
      </SubItem>
      <SubItem>
        <Name>Acknowledged</Name>
        <Type GUID="{18071995-0000-0000-0000-000000000030}">BOOL</Type>
      </SubItem>
      <Hides>
        <Hide GUID="{d83bd17e-45fd-47a2-8522-bfb66d23ca31}" />
        <Hide GUID="{17879e2b-4b9d-4c7e-bc78-7f41952102ef}" />
        <Hide GUID="{9b6dab9e-a36d-444d-a86a-7742074508b9}" />
        <Hide GUID="{220725e6-24be-4d8c-a545-3dafa0748c23}" />
        <Hide GUID="{c98852d5-8ee4-4abc-8f89-650f5371c142}" />
        <Hide GUID="{13b33959-d459-47ab-997b-9860c1063a45}" />
        <Hide GUID="{ba4fe3da-1ece-4c2d-8cbc-66214871d4aa}" />
        <Hide GUID="{d077742a-2653-400a-a69a-962da27776de}" />
      </Hides>
    </DataType>
    <!-- AMSADDR -->
    <DataType>
      <Name GUID="{18071995-0000-0000-0000-000000000042}" TcBaseType="true" CName="AmsAddr">AMSADDR</Name>
      <BitSize>64</BitSize>
      <SubItem>
        <Name>netId</Name>
        <Type GUID="{18071995-0000-0000-0000-000000000041}">AMSNETID</Type>
        <BitSize>48</BitSize>
        <BitOffs>0</BitOffs>
      </SubItem>
      <SubItem>
        <Name>port</Name>
        <Type GUID="{18071995-0000-0000-0000-000000000004}">WORD</Type>
        <BitSize>16</BitSize>
        <BitOffs>48</BitOffs>
      </SubItem>
      <Format>
        <Printf>%d.%d.%d.%d.%d.%d:%d</Printf>
        <Parameter>.netId[0]</Parameter>
        <Parameter>.netId[1]</Parameter>
        <Parameter>.netId[2]</Parameter>
        <Parameter>.netId[3]</Parameter>
        <Parameter>.netId[4]</Parameter>
        <Parameter>.netId[5]</Parameter>
        <Parameter>.port</Parameter>
      </Format>
      <Format Name="Iec">
        <Printf>(netId:=[%d.%d.%d.%d.%d.%d], port :=%d)</Printf>
        <Parameter>.netId[0]</Parameter>
        <Parameter>.netId[1]</Parameter>
        <Parameter>.netId[2]</Parameter>
        <Parameter>.netId[3]</Parameter>
        <Parameter>.netId[4]</Parameter>
        <Parameter>.netId[5]</Parameter>
        <Parameter>.port</Parameter>
      </Format>
    </DataType>
  </DataTypes>
