      </EventId>
      <EventId>
        <Name Id="#x33179103">E9103_NumberOfSubmoversNotSupported</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] The number of submovers is not supported for the coupling.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33179104">E9104_SoftwareCouplingSubmoverControlOff</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] The submover's control is off.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33179105">E9105_SoftwareCouplingInvalidSetpoints</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] The setpoints for the software coupling are invalid.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33179106">E9106_SoftwareCouplingSubmoverTouchPowerLimit</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] One of submovers touch the power limit, and the coupling is disabled.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33179108">E9108_SoftwareCouplingActiveIndexNotValid</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] The active index is not available.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
