        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x3317502E">E502E_MoverCannotBeReset</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Mover cannot be reset because part does not reset.</DisplayName>
