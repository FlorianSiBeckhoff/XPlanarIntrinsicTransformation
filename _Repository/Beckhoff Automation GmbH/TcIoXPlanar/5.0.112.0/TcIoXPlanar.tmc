        <DisplayName TxtId="">[Event ID: 0x{0,X}] Mover is not assigned to any movement area. Enabling is not possible.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x3317501F">E501F_NotAllowedToLeaveMovementAreaWhenFlying</Name>
