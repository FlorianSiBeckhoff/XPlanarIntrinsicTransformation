        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x3317002B">E002B_CoordinatedMoverComm_MoverNotAbleToIdentify</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Mover 0x{1,X} is not able to identify or has no valid BTN configured.</DisplayName>
