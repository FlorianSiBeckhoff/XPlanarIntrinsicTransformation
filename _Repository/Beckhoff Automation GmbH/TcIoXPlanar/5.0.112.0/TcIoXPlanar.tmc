      </EventId>
      <EventId>
        <Name Id="#x3317502A">E502A_Communication_CouldNotSwitchSystemOn</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] System could not be switched on. Communication aborted.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
