        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175022">E5022_NcPartNotFound</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Commanded Part OID from NC (0x{1,X}) not found.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175023">E5023_IsOnPartWithError</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Mover is on part with error. Switching into error state.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175024">E5024_UsesDeactivatedPart</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Mover uses deactivated part. Switching into error state.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175026">E5026_SystemCouldNotBeEnabled</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Mover cannot enable because the part and the tiles could not be enabled. Switching into error state.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175027">E5027_Communication_MoverHasError</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Mover has an error. Communication attempt is aborted.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175028">E5028_Communication_InvalidTileFw</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Invalid tile firmware. Firmware version must at least be 4. Communication aborted.</DisplayName>
