        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175017">E5017_MaxForceLimitsZeroIn1Dof</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Maximum force limit parameters are equal to zero in at least 1 DOF. Parameters stay the same.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175018">E5018_MinForceLimitsZeroIn1Dof</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Minimum force limit parameters are equal to zero in at least 1 DOF. Parameters stay the same.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x3317501A">E501A_NoRotationAtThisPosition</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] C setpoint is unreachable at this position. Initiating mover stop.</DisplayName>
