      </EventId>
      <EventId>
        <Name Id="#x33170040">E0040_CoordinatedMoverComm_MoverIsActivated</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] {1} mover(s) are activated, e.g. mover 0x{2,X}. Coordinated mover communication aborted.</DisplayName>
