      </EventId>
      <EventId>
        <Name Id="#x3317002D">E002D_CoordinatedMoverComm_ConfiguredBtnNotIdentified</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] The configured BTN '{1}' was not identified on the system.</DisplayName>
