      <!-- Parameters -->
      <Parameters>
        <Group Collapsed="false">Base</Group>
        <Group Collapsed="true">MoverEnablingDisabling</Group>
        <Group Collapsed="true">PositionReference</Group>
        <Group Collapsed="true">MoverCommunication</Group>
        <!-- EnablingHeight -->
        <Parameter DisableCodeGeneration="true" Group="MoverEnablingDisabling">
          <Name>zPosAtEnable</Name>
          <Comment>When enabling/activating the mover, it will fly at this Z position.</Comment>
          <BaseType GUID="{18071995-0000-0000-0000-00000000000E}">LREAL</BaseType>
          <Unit>mm</Unit>
          <Default>
            <Value>2.0</Value>
          </Default>
          <PTCID>#x03175030</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
        <!-- EnablingHeightRange-->
        <Parameter DisableCodeGeneration="true" Group="MoverEnablingDisabling" HideParameter="true">
          <Name>zRangeAtEnable</Name>
          <Comment>Acceptance range, in which the mover has to stay for a while after enabling. The acceptance region is zPosAtEnable +- zRangeAtEnable</Comment>
          <BaseType GUID="{18071995-0000-0000-0000-00000000000E}">LREAL</BaseType>
          <Unit>mm</Unit>
          <Default>
            <Value>0.1</Value>
          </Default>
          <PTCID>#x03175039</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
        <!-- TimeToStayAtEnablingHeight-->
        <Parameter DisableCodeGeneration="true" Group="MoverEnablingDisabling" HideParameter="true">
          <Name>TimeToStayAtEnablingHeight</Name>
          <Comment>After reaching the enabling height, the mover remains there for this time to ensure it is stable. Max. 4 seconds.</Comment>
          <BaseType GUID="{18071995-0000-0000-0000-00000000000E}">LREAL</BaseType>
          <Unit>s</Unit>
          <Default>
            <Value>1.0</Value>
          </Default>
          <PTCID>#x0317503A</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
        <!-- EnablingTime -->
        <Parameter DisableCodeGeneration="true" Group="MoverEnablingDisabling">
          <Name>EnablingTime</Name>
          <Comment>Defines the time that the mover needs for enabling. Has to be between 0.1s and 4s.</Comment>
          <BaseType GUID="{18071995-0000-0000-0000-00000000000E}">LREAL</BaseType>
          <Unit>s</Unit>
          <Default>
            <Value>0.5</Value>
          </Default>
          <PTCID>#x0317506B</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
        <!-- DisablingTime -->
        <Parameter DisableCodeGeneration="true" Group="MoverEnablingDisabling">
          <Name>DisablingTime</Name>
          <Comment>Defines the time that the mover needs for disabling. Has to be between 0.1s and 4s.</Comment>
          <BaseType GUID="{18071995-0000-0000-0000-00000000000E}">LREAL</BaseType>
          <Unit>s</Unit>
          <Default>
            <Value>0.5</Value>
          </Default>
          <PTCID>#x0317506C</PTCID>
          <ContextId>1</ContextId>
        </Parameter>
        <!-- SetpointInterpolation -->
        <Parameter DisableCodeGeneration="true" Group="Base">
          <Name>SetpointInterpolation</Name>
          <Comment>External setpoints can be interpolated by the setpoint dynamics or an internal calculated BSpline.</Comment>
