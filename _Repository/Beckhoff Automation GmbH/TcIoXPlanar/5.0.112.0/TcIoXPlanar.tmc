      </EventId>
      <EventId>
        <Name Id="#x33179102">E9102_SoftwareCouplingNoAvailableMemory</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] No memory can be assigned the software coupling.</DisplayName>
