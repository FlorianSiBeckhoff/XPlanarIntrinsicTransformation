    <!-- ExternalFeedbackStatus -->
    <DataType>
      <Name GUID="{FC7AD96D-DC90-4A9B-B4D8-BDA17DA624E3}" Namespace="TcIoXPlanar">ExternalFeedbackStatus</Name>
      <BaseType GUID="{18071995-0000-0000-0000-000000000006}">INT</BaseType>
      <EnumInfo>
        <Text>Idle</Text>
        <Enum>0</Enum>
      </EnumInfo>
      <EnumInfo>
        <Text>Prepared</Text>
        <Enum>1</Enum>
      </EnumInfo>
      <EnumInfo>
        <Text>Active</Text>
        <Enum>2</Enum>
      </EnumInfo>
      <EnumInfo>
        <Text>Error</Text>
        <Enum>3</Enum>
      </EnumInfo>
      <Default>
        <EnumText>Idle</EnumText>
      </Default>
