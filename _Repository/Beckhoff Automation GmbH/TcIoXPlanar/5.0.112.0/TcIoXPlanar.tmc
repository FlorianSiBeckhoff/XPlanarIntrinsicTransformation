      </EventId>
      <EventId>
        <Name Id="#x3317503C">E503C_ActivateMoverTransferFailed</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Activate mover transfer failed.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175041">E5041_Communication_MoverTransferNotActivated</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Mover is between to XPlanar systems and mover transfer is not activated. Communication aborted.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175042">E5042_Communication_OrientationBumperOutsideTile</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Mover bumper exceeds the tile area. Mover orientation cannot be determined.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175043">E5043_Communication_OrientationWrongMoverFirmware</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Wrong mover firmware. Firmware version must be greater than 3. Mover orientation cannot be determined.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175044">E5044_Communication_TransmissionFailed</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Transmission of the message to the mover failed. Mover communication failed.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175045">E5045_Communication_ReceptionFailed</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] The signal level of the mover answer is too low. Mover communication failed.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175046">E5046_Communication_DecodingFailed</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] The message received from the mover is invalid. Mover communication failed.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175047">E5047_Communication_OrientingMoverFailed</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Mover is rotated and cannot be orientated. Communication aborted.</DisplayName>
