        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x3317004D">E004D_CoordinatedMoverComm_FailedPreparation</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Preparation for mover communication of mover 0x{1,X} failed. Coordinated mover communication failed.</DisplayName>
