      </EventId>
      <EventId>
        <Name Id="#x33175048">E5048_Communication_MoverPositionChanged</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Mover position changed during communication. Mover orientation cannot be determined.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33175049">E5049_Communication_CouldNotEstablishCommunication</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] No communication could be established with the mover. Mover communication failed.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33176002">E6002_EtherCatCommunicationLost</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] EtherCAT communication is lost. System is shut down.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33176004">E6004_PowerSupplyTemperatureTooHigh</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Power supply temperature ({1,f} °C) exceeds the limit of {2,f} °C. System is shut down.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33176005">E6005_TileTemperatureTooHigh</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Tile temperature {1} ({2,f} °C) exceeds the limit of {3,f} °C. System is shut down.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33176007">E6007_HardwareError</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Hardware error</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x3317600B">E600B_CouldNotResetTile</Name>
