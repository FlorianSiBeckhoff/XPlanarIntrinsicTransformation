        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23175018">W5018_ExternalFeedbackParametrizationSetNotFound</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Defined external feedback parametrization set could not be found.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23175019">W5019_InvalidKalmanFilterParameters</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Invalid Kalman filter parameters of axis {1}. Kalman filter parameters are set to default.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23176002">W6002_TileHardwareWarning</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Tile hardware warning (Value of CoE register 0x81430: 0x{1,X}).</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23176003">W6003_FbInputsNotChangedWarning</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] FB Inputs have not changed since last cycle.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23176004">W6004_TileSwitchPositionMissedCycleWarning</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] FB Inputs were missed for one cycle.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x23176005">W6005_TileSwitchPositionImplausibleWarning</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] FB Inputs implausible switch position (expected: {1}, actual: {2}).</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x2317A001">WA001_InvalidEnablingTime</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Enabling time invalid. Must be between 0.1 s and 4.0 s.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x2317A002">WA002_InvalidDisablingTime</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Disabling time invalid. Must be between 0.1 s and 4.0 s.</DisplayName>
        <Severity>Warning</Severity>
      </EventId>
      <EventId>
        <Name Id="#x2317A003">WA003_InvalidEnablingHeight</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Enabling height invalid. Must be between 0.5 mm and 5.0 mm.</DisplayName>
