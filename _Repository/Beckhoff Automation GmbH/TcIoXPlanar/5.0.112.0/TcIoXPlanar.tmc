      </EventId>
      <EventId>
        <Name Id="#x3317002C">E002C_CoordinatedMoverComm_MoverError</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] {1} mover(s) have an error, e.g. mover 0x{2,X}. Coordinated mover communication aborted.</DisplayName>
