      </EventId>
      <EventId>
        <Name Id="#x33178009">E8009_PartDetectionNotPossible</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Part redetection is not possible.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x33179008">E9008_SubMoversInDifferentMovementArea</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Submovers are in different movement areas.</DisplayName>
        <Severity>Error</Severity>
      </EventId>
      <EventId>
        <Name Id="#x3317900E">E900E_SubMoverPositionsMismatch</Name>
        <DisplayName TxtId="">[Event ID: 0x{0,X}] Mismatch of Submovers positions.</DisplayName>
